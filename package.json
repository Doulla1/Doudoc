{
  "name": "doudoc",
  "displayName": "Doudoc",
  "description": "Workspace documentation explorer and reader for /docs",
  "version": "3.3.0",
  "publisher": "Doudou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Doulla1/Doudoc.git"
  },
  "homepage": "https://github.com/Doulla1/Doudoc#readme",
  "bugs": {
    "url": "https://github.com/Doulla1/Doudoc/issues"
  },
  "keywords": [
    "documentation",
    "markdown",
    "docs",
    "knowledge-base",
    "webview"
  ],
  "files": [
    "dist/**",
    "media/**",
    "CHANGELOG.md",
    "README.md",
    "LICENSE.txt",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#101521",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:doudoc.explorerView",
    "onCommand:doudoc.openPanel",
    "onCommand:doudoc.refresh",
    "onCommand:doudoc.openMarkdownFile",
    "onCommand:doudoc.searchDocs",
    "onCommand:doudoc.createPage",
    "onCommand:doudoc.toggleZenMode"
  ],
  "main": "./dist/extension.js",
  "icon": "media/logo.png",
  "contributes": {
    "configuration": {
      "title": "Doudoc",
      "properties": {
        "doudoc.docsPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "docs"
          ],
          "description": "List of folder paths (relative to the workspace root) scanned by Doudoc as documentation sources. Defaults to a single 'docs' folder."
        },
        "doudoc.autoSave": {
          "type": "boolean",
          "default": false,
          "description": "Auto-save the current page in edit mode after a short delay (see doudoc.autoSaveDelay)."
        },
        "doudoc.autoSaveDelay": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 60000,
          "description": "Delay (in ms) before auto-save triggers after the last edit."
        },
        "doudoc.defaultTheme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "Default theme used by the documentation panel: 'auto' follows VS Code, 'light' or 'dark' force a specific theme."
        },
        "doudoc.readingWidth": {
          "type": "string",
          "enum": [
            "narrow",
            "comfortable",
            "wide",
            "full"
          ],
          "default": "comfortable",
          "description": "Reading width of the content column: narrow (~640px), comfortable (~760px), wide (~960px) or full."
        },
        "doudoc.zenMode": {
          "type": "boolean",
          "default": false,
          "description": "Start Doudoc in zen mode (sidebar and table of contents hidden, content centered)."
        },
        "doudoc.useGitMTime": {
          "type": "boolean",
          "default": true,
          "description": "Use the date of the last git commit touching the file as 'last modified' (falls back to filesystem mtime)."
        },
        "doudoc.fuzzySearch": {
          "type": "boolean",
          "default": true,
          "description": "Allow fuzzy matches in the search index (small typo tolerance on titles and headings)."
        }
      }
    },
    "commands": [
      {
        "command": "doudoc.openPanel",
        "title": "Doudoc: Open Documentation Panel",
        "icon": "$(book)"
      },
      {
        "command": "doudoc.refresh",
        "title": "Doudoc: Refresh Documentation",
        "icon": "$(refresh)"
      },
      {
        "command": "doudoc.openMarkdownFile",
        "title": "Open with Doudoc",
        "icon": "$(book)"
      },
      {
        "command": "doudoc.searchDocs",
        "title": "Doudoc: Search Documentation",
        "icon": "$(search)"
      },
      {
        "command": "doudoc.createPage",
        "title": "Doudoc: New Documentation Page...",
        "icon": "$(new-file)"
      },
      {
        "command": "doudoc.toggleZenMode",
        "title": "Doudoc: Toggle Zen Mode",
        "icon": "$(screen-full)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "doudoc",
          "title": "Doudoc",
          "icon": "media/logo-monochrome.svg"
        }
      ]
    },
    "views": {
      "doudoc": [
        {
          "id": "doudoc.explorerView",
          "name": "Documentation",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "doudoc.openPanel",
          "when": "view == doudoc.explorerView",
          "group": "navigation"
        },
        {
          "command": "doudoc.createPage",
          "when": "view == doudoc.explorerView",
          "group": "navigation"
        },
        {
          "command": "doudoc.refresh",
          "when": "view == doudoc.explorerView",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "doudoc.openMarkdownFile",
          "when": "resourceExtname == .md",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "command": "doudoc.openMarkdownFile",
          "when": "resourceExtname == .md",
          "group": "navigation@10"
        }
      ],
      "editor/context": [
        {
          "command": "doudoc.openMarkdownFile",
          "when": "resourceExtname == .md",
          "group": "navigation@10"
        }
      ]
    },
    "keybindings": [
      {
        "command": "doudoc.searchDocs",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node ./scripts/esbuild.mjs",
    "watch": "node ./scripts/esbuild.mjs --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run check && npm test",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/linkify-it": "^5.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mdurl": "^2.0.0",
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}